# Port (5000 dipakai AirPlay macOS, pakai 5050)
PORT=5050

# DATABASE_URL untuk Mac PostgreSQL@14
DATABASE_URL="postgresql://azhr@localhost:5432/snapbooth"

# JWT Secret (generate pake openssl rand -base64 32)
JWT_SECRET="your_random_string_here"
JWT_EXPIRES_IN=8h

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Printer (dummy dulu)
PRINTER_IP="192.168.1.100"
PRINTER_PORT="631"

# Frontend URL
ALLOWED_ORIGIN="http://localhost:3000"

# Admin default
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=admin123

# Optional
FONNTE_API_KEY=""